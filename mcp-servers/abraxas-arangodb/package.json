{
  "name": "abraxas-arangodb",
  "version": "1.0.0",
  "description": "Abraxas ArangoDB MCP server - Full graph database access with AQL, collections, and traversal",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "dev:http": "bun run src/http-server.ts",
    "build": "bun build ./src/index.ts --target=bun --outdir=dist --minifyify",
    "build:tsc": "tsc",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:coverage": "bun test --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "arangojs": "^8.8.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/jest": "^29.5.12",
    "bun-types": "^1.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "keywords": [
    "abraxas",
    "mcp",
    "arangodb",
    "graph-database",
    "aql",
    "collections",
    "graphs",
    "traversal",
    "claude-code"
  ],
  "author": "Tyler Garlick <tylergarlick@users.noreply.github.com>",
  "license": "MIT",
  "mcpServer": {
    "version": "2.1",
    "features": {
      "lazyLoading": true,
      "skills2": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TylerGarlick/abraxas"
  }
}
