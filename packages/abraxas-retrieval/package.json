{
  "name": "abraxas-retrieval",
  "version": "2.0.0",
  "description": "Abraxas retrieval MCP server v2 - web search, fetch, and fact-check tools with Claude Code 2.1 support",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "test": "bun test"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "keywords": ["abraxas", "mcp", "retrieval", "search", "claude-code"],
  "license": "MIT",
  "mcpServer": {
    "version": "2.1",
    "features": {
      "lazyLoading": true,
      "skills2": true,
      "agentTeams": true
    }
  }
}
